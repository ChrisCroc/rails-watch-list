
<div class="hero" style="background-image: url(' <%= @list.photos.first.url if @list.photos.attached? %>');">
  <div class="hero-content text center text-white">
    <h1><%= @list.name %></h1>
  </div>
  <span class="badge bg-warning"><%= @list.bookmarks.count %> movies</span>
</div>

<div class="container my-4">
  <div class="d-flex justify-content-end mb-3">
    <%= link_to "Add a movie", new_list_bookmark_path(@list), class: "btn btn-success" %>
  </div>
  <div class="row g-3 justify-content-center">
    <% @list.bookmarks.each do |bookmark| %>
    <div class="col-12 col-md-4 col-lg-3">
      <div class="card">
        <% if bookmark.photos.attached? %>
          <% bookmark.photos.each do |photo| %>
            <%= cl_image_tag photo.key, height: 150, width: 450, crop: :fill, class: "card-img-top" %>
          <% end %>
        <% end %>
        <div class="card-body">
          <div>
            <h5><%= bookmark.movie.title %> | <%= bookmark.movie.rating %> ⭐️</h5>
            <p><%= bookmark.movie.overview %></p>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <p>❛<%= bookmark.comment %>❜</p>
            <%= link_to "Remove", list_bookmark_path(@list, bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure" }, id: "delete" %>
          </div>
        </div>
      </div>
    </div>
    <% end %>
  </div>
</div>
<div class="footer">
  <%= link_to "Add a movie", new_list_bookmark_path(@list) %>
  <%= link_to "My lists", lists_path %>
  <%= link_to "All Movies", movies_path %>
</div>
