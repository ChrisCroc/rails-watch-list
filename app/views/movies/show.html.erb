<div class="container">
  <h1><%= "#{@movie.title}" %></h1>
    <div>
      <img src="<%= @movie.poster_url %>" alt="<%= @movie.title %>" style="width: 200px;">
      <br>
      <p><%= @movie.overview %></p>
      <br>
      <p>Rating | <%= @movie.rating %></p>
    </div>
    <div>
      <% @lists.each do |list| %>
        <p>Add to this list: <%= link_to list.name, new_list_bookmark_path(list, movie_id: @movie_id) %></p>
      <% end %>
    </div>
    <footer>
      <%= link_to "Movies List", movies_path %>
    </footer>
</div>
